from PIL import Image, ImageEnhance
import numpy as np
from sklearn.neural_network import MLPClassifier

# 1. Load image, convert to grayscale, and resize to a small fixed size
img = Image.open("digit.png").convert("L")
img = img.resize((28, 28))

# 2. Create a slightly modified version of the same image
enhancer = ImageEnhance.Brightness(img)
img_modified = enhancer.enhance(1.2)

# 3. Convert both images into NumPy arrays
arr_original = np.array(img)
arr_modified = np.array(img_modified)

# 4. Show that pixel values are different
print("Original image pixel sample:", arr_original[0][:5])
print("Modified image pixel sample:", arr_modified[0][:5])

# 5. Measure numeric difference caused by small visual change
difference = np.abs(arr_original - arr_modified)
print("Average pixel difference:", round(difference.mean(), 2))
print("Maximum pixel difference:", difference.max())

# 6. Flatten images for MLP input
X_original = arr_original.flatten().reshape(1, -1)
X_modified = arr_modified.flatten().reshape(1, -1)

# 7. Train an MLP on the original image only
y = [0]  # dummy label for demonstration

mlp = MLPClassifier(
    hidden_layer_sizes=(50,), 
    max_iter=300, 
    random_state=42
)
mlp.fit(X_original, y)

# 8. Compare predictions
pred_original = mlp.predict_proba(X_original)
pred_modified = mlp.predict_proba(X_modified)

print("Prediction for original image:", pred_original)
print("Prediction for modified image:", pred_modified)
