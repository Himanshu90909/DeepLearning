import os
import numpy as np
from PIL import Image
from sklearn.neural_network import MLPClassifier
from sklearn.model_selection import train_test_split

# 1. Load images and labels

X = []  # image data
y = []  # labels

IMAGE_SIZE = (28, 28)

dataset_path = "dataset"

# Each folder name represents a class:
# images in "circle" → label 0, images in "square" → label 1
for label_name, label_value in [("circle", 0), ("square", 1)]:
    class_folder = os.path.join(dataset_path, label_name)

    # Go through every image file inside the current class folder
    for file_name in os.listdir(class_folder):
        img_path = os.path.join(class_folder, file_name)

        # Load image, convert to grayscale, resize
        img = Image.open(img_path).convert("L")
        img = img.resize(IMAGE_SIZE)

        # Convert image to NumPy array
        img_array = np.array(img)

        # Flatten image
        X.append(img_array.flatten())
        y.append(label_value)

# Convert lists to NumPy arrays
X = np.array(X)
y = np.array(y)

print("Total images:", len(X))
print("Image vector size:", X.shape[1])

# 2. Normalize pixel values
X = X / 255.0  # scale pixels to range 0–1

# 3. Train-test split
X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.25, random_state=42
)

# 4. Train MLP Classifier
mlp = MLPClassifier(
    hidden_layer_sizes=(32,),
    activation="relu",
    solver="adam",
    max_iter=2000,
    random_state=42
)

mlp.fit(X_train, y_train)

# 5. Make predictions
predictions = mlp.predict(X_test)

# 7. Show a few predictions

for i in range(min(5, len(X_test))):
    print(
        f"Actual: {'Circle' if y_test[i] == 0 else 'Square'} | "
        f"Predicted: {'Circle' if predictions[i] == 0 else 'Square'}"
    )
