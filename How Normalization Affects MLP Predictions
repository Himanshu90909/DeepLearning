from PIL import Image, ImageEnhance
import numpy as np
from sklearn.neural_network import MLPRegressor

# 1. Load the digit image, convert to grayscale, resize
img = Image.open("digit.png").convert("L")
img = img.resize((28, 28))

# 2. Create a slightly modified version of the same image (simulate brightness change)
enhancer = ImageEnhance.Brightness(img)
img_modified = enhancer.enhance(1.2)

# 3. Convert images to NumPy arrays
arr_original = np.array(img)
arr_modified = np.array(img_modified)

# 4. Flatten arrays for MLP input
X_original = arr_original.flatten().reshape(1, -1)
X_modified = arr_modified.flatten().reshape(1, -1)

# 5. Train MLP on original image WITHOUT normalization
y_original = [1]  # target value (example)
mlp_raw = MLPRegressor(hidden_layer_sizes=(4,), max_iter=1000, random_state=42)
mlp_raw.fit(X_original, y_original)

pred_raw = mlp_raw.predict(X_modified)
print("Prediction WITHOUT normalization:", round(pred_raw[0], 2))

# 6. Normalize pixel values (scale to 0-1)
X_original_norm = X_original / 255.0
X_modified_norm = X_modified / 255.0

# 7. Train MLP on normalized data
mlp_norm = MLPRegressor(hidden_layer_sizes=(4,), max_iter=1000, random_state=42)
mlp_norm.fit(X_original_norm, y_original)

pred_norm = mlp_norm.predict(X_modified_norm)
print("Prediction WITH normalization:", round(pred_norm[0], 2))
